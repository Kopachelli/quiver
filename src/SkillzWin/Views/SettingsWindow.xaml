<ui:FluentWindow x:Class="SkillzWin.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="Quiver Settings" Width="640" Height="640"
                 WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings"/>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SkillzCanvasBrush}">
            <StackPanel>

                <!-- GENERAL -->
                <TextBlock Text="GENERAL" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,8,0,8"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Appearance" Style="{StaticResource SkillzBodyText}"/>
                        <TextBlock Text="System follows your Windows light/dark setting." Style="{StaticResource SkillzCaptionText}"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="150" VerticalAlignment="Center"
                              ItemsSource="{Binding Appearances}"
                              SelectedItem="{Binding Settings.Appearance, Mode=TwoWay}"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Hide Cursor's built-in skills" Style="{StaticResource SkillzBodyText}" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.HideBuiltInCursorSkills, Mode=TwoWay}"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Hide Codex .system skills" Style="{StaticResource SkillzBodyText}" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.HideSystemCodexSkills, Mode=TwoWay}"/>
                </Grid>

                <Button Content="Show onboarding again" Style="{StaticResource SkillzTextButton}" HorizontalAlignment="Left"
                        Margin="0,4,0,0" Command="{Binding ShowOnboardingAgainCommand}"/>

                <Border Style="{StaticResource SkillzHairline}" Margin="0,20,0,16"/>

                <!-- EDITOR -->
                <TextBlock Text="EDITOR" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Editor font size" Style="{StaticResource SkillzBodyText}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Slider Width="180" Minimum="10" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Value="{Binding Settings.EditorFontSize, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding Settings.EditorFontSize, StringFormat={}{0} pt}" Width="48"
                                   Style="{StaticResource SkillzCaptionText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Show inspector by default" Style="{StaticResource SkillzBodyText}" VerticalAlignment="Center"/>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.ShowInspector, Mode=TwoWay}"/>
                </Grid>

                <Border Style="{StaticResource SkillzHairline}" Margin="0,20,0,16"/>

                <!-- SOURCES -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SOURCES" Style="{StaticResource SkillzSectionHeaderText}" VerticalAlignment="Center"/>
                        <comp:Tag Text="{Binding DetectedCount, StringFormat={}{0} detected}" Variant="Muted" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SkillzTextButton}" Command="{Binding RefreshSourcesCommand}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding SourceStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SkillzCanvasBrush}" CornerRadius="10"
                                    BorderBrush="{DynamicResource SkillzHairlineBrush}" BorderThickness="1"
                                    Padding="12" Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <comp:Tag Text="{Binding Platform, Converter={StaticResource PlatformDisplay}}" Variant="Subtle"/>
                                            <comp:Tag Text="{Binding StatusLabel}" Variant="Muted" Margin="6,0,0,0"/>
                                            <comp:Tag Text="{Binding ItemCount, StringFormat={}{0} items}" Variant="Subtle" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding PrimaryPath}" Style="{StaticResource SkillzCaptionText}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Reveal" Style="{StaticResource SkillzTextButton}" VerticalAlignment="Center"
                                            Command="{Binding DataContext.RevealPathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding PrimaryPath}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
