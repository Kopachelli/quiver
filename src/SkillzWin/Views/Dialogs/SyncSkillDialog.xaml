<ui:FluentWindow x:Class="SkillzWin.Views.Dialogs.SyncSkillDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="Sync skill" Width="520" Height="560"
                 WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sync skill"/>

        <StackPanel Grid.Row="1" Margin="24,8,24,8" Background="{DynamicResource SkillzCanvasBrush}">
            <TextBlock Style="{StaticResource SkillzHeadlineText}">
                <Run Text="Sync “"/><Run Text="{Binding SkillName, Mode=OneWay}"/><Run Text="” to your tools"/>
            </TextBlock>
            <TextBlock Text="Copies the entire skill folder into each tool you select. Tools that already have it are locked."
                       Style="{StaticResource SkillzBodySecondaryText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" Padding="24,4,24,4" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SkillzCanvasBrush}">
            <ItemsControl ItemsSource="{Binding Targets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SkillzCanvasBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource SkillzHairlineBrush}" BorderThickness="1"
                                Padding="12,10" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding CanToggle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <comp:Tag Text="{Binding DisplayName}" Variant="Subtle" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding SkillsPath}" Style="{StaticResource SkillzCaptionText}"
                                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                </StackPanel>
                                <comp:Tag Grid.Column="2" Text="{Binding StatusText}" Variant="Muted" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="24,12" Background="{DynamicResource SkillzCanvasBrush}">
            <StackPanel>
                <TextBlock Text="{Binding ResultMessage}" Style="{StaticResource SkillzCaptionText}"
                           Foreground="{DynamicResource SkillzSectionLabelBrush}" TextWrapping="Wrap" Margin="0,0,0,10"
                           Visibility="{Binding ResultMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
                <Grid>
                    <Button Content="Cancel" Style="{StaticResource SkillzPillButton}" HorizontalAlignment="Left" IsCancel="True"/>
                    <Button Content="Sync" Style="{StaticResource SkillzPillButtonProminent}" HorizontalAlignment="Right"
                            IsDefault="True" Command="{Binding SyncCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
