<ui:FluentWindow x:Class="SkillzWin.Views.Dialogs.RenameSkillDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="Rename Skill" Width="460" Height="340"
                 WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Rename Skill"/>

        <StackPanel Grid.Row="1" Margin="24,8,24,8" Background="{DynamicResource SkillzCanvasBrush}">
            <TextBlock Text="Rename Skill" Style="{StaticResource SkillzHeadlineText}"/>
            <TextBlock Text="Renames the folder on disk and updates the name in SKILL.md."
                       Style="{StaticResource SkillzBodySecondaryText}" Margin="0,4,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <TextBlock Text="Platform" Style="{StaticResource SkillzDetailLabelText}" Width="72" VerticalAlignment="Center"/>
                <comp:Tag Text="{Binding PlatformName}" Variant="Subtle"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Location" Style="{StaticResource SkillzDetailLabelText}" Width="72"/>
                <TextBlock Text="{Binding Location}" Style="{StaticResource SkillzMonoText}" TextWrapping="Wrap" MaxWidth="320"/>
            </StackPanel>

            <TextBlock Text="FOLDER NAME" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
            <ui:TextBox Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource SkillzCaptionText}"
                       Foreground="{DynamicResource SkillzSectionLabelBrush}" Margin="0,12,0,0" TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
        </StackPanel>

        <Border Grid.Row="2" Padding="24,12" Background="{DynamicResource SkillzCanvasBrush}">
            <Grid>
                <Button Content="Cancel" Style="{StaticResource SkillzPillButton}" HorizontalAlignment="Left" IsCancel="True"/>
                <Button Content="Rename" Style="{StaticResource SkillzPillButtonProminent}" HorizontalAlignment="Right"
                        IsDefault="True" Command="{Binding RenameCommand}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
