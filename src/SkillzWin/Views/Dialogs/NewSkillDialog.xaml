<ui:FluentWindow x:Class="SkillzWin.Views.Dialogs.NewSkillDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="New Skill" Width="540" Height="640"
                 WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="New Skill"/>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,8" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SkillzCanvasBrush}">
            <StackPanel>
                <TextBlock Text="New Skill" Style="{StaticResource SkillzHeadlineText}"/>
                <TextBlock Text="Creates a skill folder with SKILL.md in each selected platform's skills directory."
                           Style="{StaticResource SkillzBodySecondaryText}" Margin="0,4,0,0"/>

                <TextBlock Text="NAME" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ui:TextBox PlaceholderText="e.g. code-review"
                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                <TextBlock Text="DESCRIPTION" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ui:TextBox PlaceholderText="What does this skill do?"
                            Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56"/>

                <TextBlock Text="PLATFORMS" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ItemsControl ItemsSource="{Binding Platforms}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:ToggleSwitch Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <comp:Tag Text="{Binding DisplayName}" Variant="Subtle"/>
                                        <TextBlock Text="{Binding NotDetectedHint}" Style="{StaticResource SkillzCaptionText}"
                                                   Foreground="{DynamicResource SkillzSectionLabelBrush}" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding SkillsPath}" Style="{StaticResource SkillzCaptionText}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="MARKDOWN" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="140"
                         HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource SkillzMonoFont}" FontSize="13"/>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource SkillzCaptionText}"
                           Foreground="{DynamicResource SkillzSectionLabelBrush}" Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="24,12" Background="{DynamicResource SkillzCanvasBrush}">
            <Grid>
                <Button Content="Cancel" Style="{StaticResource SkillzPillButton}" HorizontalAlignment="Left"
                        IsCancel="True"/>
                <Button Content="Create" Style="{StaticResource SkillzPillButtonProminent}" HorizontalAlignment="Right"
                        IsDefault="True" Command="{Binding CreateCommand}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
