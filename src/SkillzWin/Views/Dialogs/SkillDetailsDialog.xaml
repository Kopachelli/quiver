<ui:FluentWindow x:Class="SkillzWin.Views.Dialogs.SkillDetailsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="Skill Details" Width="460" Height="500"
                 WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Skill Details"/>

        <ScrollViewer Grid.Row="1" Padding="24,8" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SkillzCanvasBrush}">
            <StackPanel>
                <TextBlock Text="Skill Details" Style="{StaticResource SkillzHeadlineText}"/>
                <TextBlock Text="{Binding BlockedReason}" Style="{StaticResource SkillzBodySecondaryText}" Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding BlockedReason, Converter={StaticResource NullOrEmptyToVis}}"/>

                <TextBlock Text="NAME" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            IsEnabled="{Binding CanModify}"/>

                <TextBlock Text="DESCRIPTION" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" IsEnabled="{Binding CanModify}"/>

                <TextBlock Text="VERSION (OPTIONAL)" Style="{StaticResource SkillzSectionHeaderText}" Margin="0,16,0,4"/>
                <ui:TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            IsEnabled="{Binding CanModify}"/>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <TextBlock Text="Platform" Style="{StaticResource SkillzDetailLabelText}" Width="72" VerticalAlignment="Center"/>
                    <comp:Tag Text="{Binding PlatformName}" Variant="Subtle"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Path" Style="{StaticResource SkillzDetailLabelText}" Width="72"/>
                    <TextBlock Text="{Binding RootPath}" Style="{StaticResource SkillzMonoText}" TextWrapping="Wrap" MaxWidth="320"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource SkillzCaptionText}"
                           Foreground="{DynamicResource SkillzSectionLabelBrush}" Margin="0,12,0,0" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="24,12" Background="{DynamicResource SkillzCanvasBrush}">
            <Grid>
                <Button Content="Cancel" Style="{StaticResource SkillzPillButton}" HorizontalAlignment="Left" IsCancel="True"/>
                <Button Content="Save" Style="{StaticResource SkillzPillButtonProminent}" HorizontalAlignment="Right"
                        IsDefault="True" Command="{Binding SaveCommand}" IsEnabled="{Binding CanModify}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
