<UserControl x:Class="SkillzWin.Views.Components.DetailRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Margin="0,0,0,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="88"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding Label, ElementName=Root}"
                   Style="{StaticResource SkillzDetailLabelText}" Margin="0,2,0,0"/>
        <TextBox Grid.Column="1" Text="{Binding Value, ElementName=Root, Mode=OneWay}"
                 IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"
                 TextWrapping="Wrap" IsTabStop="False"
                 FontFamily="{StaticResource SkillzMonoFont}" FontSize="12"
                 Foreground="{DynamicResource SkillzEmphasisBrush}"/>
    </Grid>
</UserControl>
