<UserControl x:Class="SkillzWin.Views.DetailContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:SkillzWin.Views.Components"
             xmlns:v="clr-namespace:SkillzWin.Views"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="{DynamicResource SkillzCanvasBrush}">

    <UserControl.Resources>

        <!-- ============ SKILL (editor) ============ -->
        <DataTemplate x:Key="SkillTemplate">
            <Grid Background="{DynamicResource SkillzCanvasBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,24,24,12">
                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SkillzNavigationTitleText}"/>
                    <Button Command="{Binding RevealFolderCommand}" HorizontalAlignment="Left" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="0,2,0,0"
                            ToolTip="Reveal skill folder in Explorer">
                        <TextBlock Text="{Binding RootDirectory}" Style="{StaticResource SkillzCaptionText}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="640"/>
                    </Button>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource SkillzBodySecondaryText}"
                               MaxHeight="54" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <comp:Tag Text="{Binding Platform, Converter={StaticResource PlatformDisplay}}" Variant="Subtle"/>
                        <comp:Tag Text="Built-in" Variant="Muted" Margin="6,0,0,0"
                                  Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVis}}"/>
                        <comp:Tag Text="{Binding SaveStatusText}" Variant="Muted" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource SkillzHairline}"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="168"
                            Visibility="{Binding HasMultipleFiles, Converter={StaticResource BoolToVis}}"
                            BorderBrush="{DynamicResource SkillzHairlineBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer>
                            <StackPanel Margin="8,12">
                                <TextBlock Text="FILES" Style="{StaticResource SkillzSectionHeaderText}" Margin="8,0,8,8"/>
                                <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                                         Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RelativeName}" Style="{StaticResource SkillzNavItemText}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <avalon:TextEditor Grid.Column="1"
                                       v:AvalonEditBehavior.BoundText="{Binding EditorText, Mode=TwoWay}"
                                       FontFamily="{StaticResource SkillzMonoFont}" FontSize="{Binding EditorFontSize}" WordWrap="True"
                                       Padding="16" BorderThickness="0" ShowLineNumbers="False"
                                       Background="{DynamicResource SkillzCanvasBrush}"
                                       Foreground="{DynamicResource SkillzEmphasisBrush}"
                                       HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- ============ MCP ============ -->
        <DataTemplate x:Key="McpTemplate">
            <ScrollViewer Background="{DynamicResource SkillzCanvasBrush}">
                <StackPanel Margin="24">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource SkillzNavigationTitleText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <comp:Tag Text="{Binding Platform, Converter={StaticResource PlatformDisplay}}" Variant="Subtle"/>
                        <comp:Tag Text="{Binding TransportLabel}" Variant="Muted" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBox Text="{Binding EndpointSummary, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" Padding="0" Margin="0,8,0,0" TextWrapping="Wrap" IsTabStop="False"
                             FontFamily="{StaticResource SkillzMonoFont}" FontSize="12"
                             Foreground="{DynamicResource SkillzMutedBrush}"/>

                    <comp:DetailCard Header="Server Details" Margin="0,24,0,0">
                        <StackPanel>
                            <comp:DetailRow Label="Name" Value="{Binding Name}"/>
                            <comp:DetailRow Label="Transport" Value="{Binding TransportLabel}"/>
                            <comp:DetailRow Label="Command" Value="{Binding Command}"
                                            Visibility="{Binding Command, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <comp:DetailRow Label="Arguments" Value="{Binding Args, Converter={StaticResource ArgsJoin}}"
                                            Visibility="{Binding Args, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <comp:DetailRow Label="URL" Value="{Binding Url}"
                                            Visibility="{Binding Url, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <comp:DetailRow Label="Environment" Value="{Binding EnvKeys, Converter={StaticResource EnvKeys}}"
                                            Visibility="{Binding EnvKeys, Converter={StaticResource NullOrEmptyToVis}}"/>
                        </StackPanel>
                    </comp:DetailCard>

                    <comp:DetailCard Header="Configuration File" Margin="0,16,0,0">
                        <TextBox Text="{Binding ConfigFileUrl, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Padding="0" TextWrapping="Wrap" IsTabStop="False"
                                 FontFamily="{StaticResource SkillzMonoFont}" FontSize="12"
                                 Foreground="{DynamicResource SkillzEmphasisBrush}"/>
                    </comp:DetailCard>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Reveal Config" Style="{StaticResource SkillzTextButton}"
                                Command="{Binding DataContext.RevealPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding ConfigFileUrl}"/>
                        <Button Content="Open in Default App" Style="{StaticResource SkillzTextButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding ConfigFileUrl}"/>
                        <Button Content="Copy Path" Style="{StaticResource SkillzTextButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding ConfigFileUrl}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ============ PLUGIN ============ -->
        <DataTemplate x:Key="PluginTemplate">
            <ScrollViewer Background="{DynamicResource SkillzCanvasBrush}">
                <StackPanel Margin="24">
                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SkillzNavigationTitleText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <comp:Tag Text="{Binding Platform, Converter={StaticResource PlatformDisplay}}" Variant="Subtle"/>
                        <comp:Tag Text="{Binding IsEnabled, Converter={StaticResource EnabledText}}" Variant="Subtle" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource SkillzBodySecondaryText}" Margin="0,8,0,0"/>

                    <comp:DetailCard Header="Plugin Details" Margin="0,24,0,0">
                        <StackPanel>
                            <comp:DetailRow Label="ID" Value="{Binding PluginId}"/>
                            <comp:DetailRow Label="Marketplace" Value="{Binding Marketplace}"
                                            Visibility="{Binding Marketplace, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <comp:DetailRow Label="Version" Value="{Binding Version}"
                                            Visibility="{Binding Version, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <comp:DetailRow Label="Skills" Value="{Binding SkillCount}"/>
                            <comp:DetailRow Label="Status" Value="{Binding IsEnabled, Converter={StaticResource EnabledText}}"/>
                        </StackPanel>
                    </comp:DetailCard>

                    <comp:DetailCard Header="Install Location" Margin="0,16,0,0"
                                     Visibility="{Binding InstallPath, Converter={StaticResource NullOrEmptyToVis}}">
                        <TextBox Text="{Binding InstallPath, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Padding="0" TextWrapping="Wrap" IsTabStop="False"
                                 FontFamily="{StaticResource SkillzMonoFont}" FontSize="12"
                                 Foreground="{DynamicResource SkillzEmphasisBrush}"/>
                    </comp:DetailCard>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Reveal in Explorer" Style="{StaticResource SkillzTextButton}"
                                Visibility="{Binding InstallPath, Converter={StaticResource NullOrEmptyToVis}}"
                                Command="{Binding DataContext.RevealPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding InstallPath}"/>
                        <Button Content="Open Metadata" Style="{StaticResource SkillzTextButton}" Margin="8,0,0,0"
                                Visibility="{Binding MetadataPath, Converter={StaticResource NullOrEmptyToVis}}"
                                Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding MetadataPath}"/>
                        <Button Content="Copy Path" Style="{StaticResource SkillzTextButton}" Margin="8,0,0,0"
                                Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType={x:Type v:DetailContainerView}}}"
                                CommandParameter="{Binding InstallPath}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <v:DetailTemplateSelector x:Key="DetailSelector"
                                  SkillTemplate="{StaticResource SkillTemplate}"
                                  McpTemplate="{StaticResource McpTemplate}"
                                  PluginTemplate="{StaticResource PluginTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentDetail}"
                        ContentTemplateSelector="{StaticResource DetailSelector}"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

        <comp:EmptyState Title="No Selection"
                         Message="Select a skill, MCP server, or plugin to view details."
                         Visibility="{Binding CurrentDetail, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=invert}"/>
    </Grid>
</UserControl>
