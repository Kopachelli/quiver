<ui:FluentWindow x:Class="SkillzWin.Views.OnboardingWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:comp="clr-namespace:SkillzWin.Views.Components"
                 Title="Welcome to Quiver" Width="760" Height="600"
                 WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
                 ShowInTaskbar="False" WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Welcome"/>

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="28,8,28,8">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource SkillzAccentBrush}" VerticalAlignment="Center">
                    <TextBlock Text="Q" FontFamily="Segoe UI" FontWeight="Bold" FontSize="26"
                               Foreground="{DynamicResource SkillzOnAccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppName}" FontFamily="{StaticResource SkillzMonoFont}" FontWeight="SemiBold"
                               FontSize="24" Foreground="{DynamicResource SkillzEmphasisBrush}"/>
                    <TextBlock Text="{Binding Tagline}" Style="{StaticResource SkillzBodySecondaryText}"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Style="{StaticResource SkillzBodyText}" Margin="0,16,0,0" TextWrapping="Wrap"
                       Text="Quiver scans your agent harness folders automatically — skills, MCP servers, and plugins from Cursor, Claude Code, Codex, Hermes, Pi, and OpenCode. Everything you edit here writes straight back to those tools."/>
        </StackPanel>

        <!-- Detected tools -->
        <Grid Grid.Row="2" Margin="28,8,28,8">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="DETECTED ON THIS PC" Style="{StaticResource SkillzSectionHeaderText}" VerticalAlignment="Center"/>
                <comp:Tag Text="{Binding DetectedCount, StringFormat={}{0} found}" Variant="Muted" Margin="8,0,0,0"/>
            </StackPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SourceStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SkillzCanvasBrush}" CornerRadius="10"
                                    BorderBrush="{DynamicResource SkillzHairlineBrush}" BorderThickness="1"
                                    Padding="12" Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <comp:Tag Text="{Binding Platform, Converter={StaticResource PlatformDisplay}}" Variant="Subtle"/>
                                            <comp:Tag Text="{Binding StatusLabel}" Variant="Muted" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DetectionLabel}" Style="{StaticResource SkillzCaptionText}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <comp:Tag Grid.Column="1" Text="{Binding HookSupportLabel}" Variant="Subtle" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="28,14" Background="{DynamicResource SkillzCanvasBrush}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Show inspector by default" Style="{StaticResource SkillzBodyText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:ToggleSwitch IsChecked="{Binding Settings.ShowInspector, Mode=TwoWay}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Get Started" Style="{StaticResource SkillzPillButtonProminent}"
                        Command="{Binding GetStartedCommand}"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
