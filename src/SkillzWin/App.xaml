<Application x:Class="SkillzWin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:SkillzWin.Themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Themes/Colors.Light.xaml" />
                <ResourceDictionary Source="Themes/Typography.xaml" />
                <ResourceDictionary Source="Themes/Spacing.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared converters -->
            <conv:ToUpperConverter x:Key="ToUpper" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVis" />
            <conv:CompactPathConverter x:Key="CompactPath" />
            <conv:AgentPlatformDisplayConverter x:Key="PlatformDisplay" />
            <conv:BoolToEnabledTextConverter x:Key="EnabledText" />
            <conv:CatalogSubtitleConverter x:Key="Subtitle" />
            <conv:ArgsJoinConverter x:Key="ArgsJoin" />
            <conv:EnvKeysDisplayConverter x:Key="EnvKeys" />
            <conv:BoolToGridLengthConverter x:Key="BoolToGridLength" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
