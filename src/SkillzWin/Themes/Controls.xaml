<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:comp="clr-namespace:SkillzWin.Views.Components">

    <!-- ============================================================
         Keyed text styles — map of SkillzTextStyles.swift modifiers.
         All mono. Applied explicitly (Style="{StaticResource ...}").
         ============================================================ -->

    <Style x:Key="SkillzNavigationTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontNavTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="SkillzHeadlineText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontHeadline}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
    </Style>

    <Style x:Key="SkillzTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontTitle}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
    </Style>

    <Style x:Key="SkillzListTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontListTitle}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="SkillzNavItemText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontNavItem}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
    </Style>

    <Style x:Key="SkillzBodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontBody}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SkillzBodySecondaryText" TargetType="TextBlock" BasedOn="{StaticResource SkillzBodyText}">
        <Setter Property="Foreground" Value="{DynamicResource SkillzMutedBrush}"/>
    </Style>

    <Style x:Key="SkillzCaptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontCaption}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzMutedBrush}"/>
    </Style>

    <Style x:Key="SkillzCaptionStrongText" TargetType="TextBlock" BasedOn="{StaticResource SkillzCaptionText}">
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style x:Key="SkillzSectionHeaderText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontSection}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzSectionLabelBrush}"/>
    </Style>

    <Style x:Key="SkillzMonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontMono}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
    </Style>

    <Style x:Key="SkillzDetailLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontCaptionMedium}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzSectionLabelBrush}"/>
    </Style>

    <Style x:Key="SkillzDetailValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="{StaticResource SkillzFontBody}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- 1px hairline separator -->
    <Style x:Key="SkillzHairline" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource SkillzHairlineBrush}"/>
    </Style>

    <!-- ============================================================
         Toolbar pill buttons (SkillzGlassToolbarButton family)
         ============================================================ -->

    <Style x:Key="SkillzPillButton" TargetType="Button">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontFamily" Value="{StaticResource SkillzMonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SkillzCanvasBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SkillzHairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="{StaticResource PillRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            <Setter Property="Foreground" Value="{DynamicResource SkillzMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SkillzPillButtonProminent" TargetType="Button" BasedOn="{StaticResource SkillzPillButton}">
        <Setter Property="Background" Value="{DynamicResource SkillzInkBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzCanvasBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="SkillzIconButton" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Foreground" Value="{DynamicResource SkillzEmphasisBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="{StaticResource RowRadius}" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource SkillzSelectionHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource SkillzMutedBrush}"/>
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Detail-screen text action button (SkillzTextButton, outline) -->
    <Style x:Key="SkillzTextButton" TargetType="Button" BasedOn="{StaticResource SkillzPillButton}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SkillzEmphasisBorderBrush}"/>
    </Style>

    <!-- ============================================================
         DetailCard (HeaderedContentControl-style card)
         ============================================================ -->
    <Style TargetType="{x:Type comp:DetailCard}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:DetailCard}">
                    <Border Background="{DynamicResource SkillzCanvasBrush}"
                            CornerRadius="{StaticResource CardRadius}"
                            BorderBrush="{DynamicResource SkillzHairlineBrush}"
                            BorderThickness="1" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ToUpper}}"
                                       Style="{StaticResource SkillzSectionHeaderText}" Margin="0,0,0,10"/>
                            <ContentPresenter/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
